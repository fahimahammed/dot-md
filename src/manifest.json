{
  "manifest_version": 3,
  "name": "dot-md",
  "short_name": "dot-md",
  "version": "1.2.0",
  "description": "Convert any webpage into clean Markdown",
  "author": "Fahim Ahammed Firoz",
  "homepage_url": "https://github.com/fahimahammed/dot-md",
  "offline_enabled": true,
  "minimum_chrome_version": "88",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "dot-md",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

